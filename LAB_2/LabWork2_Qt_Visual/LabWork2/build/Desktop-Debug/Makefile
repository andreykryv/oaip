src/main.s: src/main.cpp.s
.PHONY : src/main.s

# target to generate assembly for a file
src/main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/LabWork2App.dir/build.make CMakeFiles/LabWork2App.dir/src/main.cpp.s
.PHONY : src/main.cpp.s

